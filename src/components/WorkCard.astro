---
interface Props {
  title: string;
  category: string;
  description: string;
  meta: string;
}

const { title, category, description, meta } = Astro.props;
---

<article class="rounded-3xl border border-line/80 bg-surface/95 p-6 shadow-card transition-transform duration-200 hover:-translate-y-1">
  <p class="font-mono text-xs uppercase tracking-[0.2em] text-muted">{category}</p>
  <h3 class="mt-3 font-serif text-2xl leading-tight text-ink">{title}</h3>
  <p class="mt-4 text-base leading-8 text-muted">{description}</p>
  <p class="mt-6 font-mono text-xs uppercase tracking-[0.16em] text-muted">{meta}</p>
</article>

