---
interface Props {
  id: string;
  label: string;
  intro?: string;
  delay?: string;
}

const { id, label, intro, delay = "0ms" } = Astro.props;
---

<section id={id} class="divider section-reveal scroll-mt-24 py-16 md:py-20" style={`animation-delay:${delay};`}>
  <div class="mx-auto max-w-4xl">
    <p class="section-label">{label}</p>
    <div class="mt-6 space-y-4">
      {intro && <p class="mx-auto max-w-2xl text-center text-base leading-8 text-muted">{intro}</p>}
      <slot />
    </div>
  </div>
</section>
