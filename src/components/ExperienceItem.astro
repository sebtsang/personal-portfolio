---
interface Props {
  company: string;
  role: string;
  period: string;
  logo: string;
  logoAlt: string;
  highlights: string[];
}

const { company, role, period, logo, logoAlt, highlights } = Astro.props;
---

<article class="experience-entry" data-cursor-hover>
  <div class="grid gap-4 md:grid-cols-[84px_minmax(0,1fr)] md:gap-6">
    <div class="flex items-start md:pt-1">
      <div class="experience-logo-shell">
        <img
          src={logo}
          alt={logoAlt}
          class="experience-logo-image"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
    <div>
      <div class="flex flex-col gap-2 md:flex-row md:items-start md:justify-between">
        <div class="space-y-1">
          <p class="font-sans text-[1.3rem] font-medium leading-tight tracking-[-0.02em] text-ink md:text-[1.55rem]">
            {company}
          </p>
          <h3 class="max-w-2xl font-sans text-[1.02rem] leading-tight text-muted md:text-[1.18rem]">
            {role}
          </h3>
        </div>
        <p class="font-mono text-[0.72rem] uppercase tracking-[0.16em] text-muted md:pt-1">{period}</p>
      </div>
      <ul class="mt-4 space-y-1.5 text-sm leading-7 text-ink/90 md:text-[0.98rem]">
        {highlights.map((item) => (
          <li class="flex gap-3">
            <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</article>
