---
import Icon from "./Icon.astro";

interface NavItem {
  href: string;
  label: string;
}

interface Props {
  name: string;
  navItems: NavItem[];
}

const { name, navItems } = Astro.props;
---

<header class="site-header">
  <div class="site-header__inner">
    <a href="#top" class="site-brand">{name}</a>

    <nav class="site-nav" aria-label="Section navigation">
      {navItems.map((item) => (
        <a href={item.href} class="site-nav__link">{item.label}</a>
      ))}
    </nav>

    <button
      class="header-theme-toggle"
      type="button"
      aria-label="Toggle color theme"
      aria-pressed="false"
      data-theme-toggle
    >
      <span class="header-theme-toggle__icon header-theme-toggle__icon--sun">
        <Icon name="sun" class="h-[1.28rem] w-[1.28rem]" />
      </span>
      <span class="header-theme-toggle__icon header-theme-toggle__icon--moon">
        <Icon name="moon" class="h-[1.28rem] w-[1.28rem]" />
      </span>
    </button>
  </div>
</header>
