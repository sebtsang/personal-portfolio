---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Sebastian Tsang",
  description = "Single-page portfolio for Sebastian Tsang, a Computer Science student focused on practical AI and data systems.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f7f4ee" />
    <title>{title}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <script is:inline>
      (() => {
        const storedTheme = localStorage.getItem("portfolio-theme");
        const theme =
          storedTheme ??
          (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
        document.documentElement.dataset.theme = theme;
      })();
    </script>
  </head>
  <body>
    <slot />
    <script is:inline>
      const root = document.documentElement;
      const button = document.querySelector("[data-theme-toggle]");
      const timeline = document.querySelector("[data-timeline]");
      const timelineProgress = timeline?.querySelector(".experience-timeline__progress");

      if (button) {
        const syncThemeButton = () => {
          const isDark = root.dataset.theme === "dark";
          button.setAttribute("aria-pressed", isDark ? "true" : "false");
        };

        syncThemeButton();

        button.addEventListener("click", () => {
          root.dataset.theme = root.dataset.theme === "dark" ? "light" : "dark";
          localStorage.setItem("portfolio-theme", root.dataset.theme);
          syncThemeButton();
        });
      }

      if (timeline && timelineProgress) {
        const updateTimeline = () => {
          const timelineRect = timeline.getBoundingClientRect();
          const logos = timeline.querySelectorAll(".experience-logo-shell");
          const firstLogo = logos[0];
          const lastLogo = logos[logos.length - 1];

          if (!firstLogo || !lastLogo) return;

          const firstRect = firstLogo.getBoundingClientRect();
          const lastRect = lastLogo.getBoundingClientRect();
          const start = firstRect.top - timelineRect.top + firstRect.height / 2;
          const end = lastRect.top - timelineRect.top + lastRect.height / 2;
          const total = Math.max(end - start, 1);
          const viewport = window.innerHeight;
          const trigger = viewport * 0.62;
          const triggerWithinTimeline = trigger - timelineRect.top;
          const raw = (triggerWithinTimeline - start) / total;
          const progress = Math.max(0, Math.min(1, raw));
          timeline.style.setProperty("--timeline-start", `${start}px`);
          timeline.style.setProperty("--timeline-height", `${total}px`);
          const bgProgress = Math.max(0, Math.min(1, raw * 1.3));
          timeline.style.setProperty("--timeline-bg-progress", `${bgProgress}`);
          timelineProgress.style.setProperty("--timeline-progress", `${progress}`);
        };

        updateTimeline();
        window.addEventListener("scroll", updateTimeline, { passive: true });
        window.addEventListener("resize", updateTimeline);
      }

      /* ── Scroll-triggered reveals ── */
      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const revealEls = document.querySelectorAll(".reveal");
      const experienceEntries = document.querySelectorAll("[data-timeline] .experience-entry");

      experienceEntries.forEach((entry, i) => {
        entry.classList.add("reveal");
        entry.style.transitionDelay = `${(i + 1) * 100}ms`;
      });

      if (prefersReducedMotion) {
        revealEls.forEach((el) => el.classList.add("is-visible"));
        experienceEntries.forEach((el) => el.classList.add("is-visible"));
      } else {
        const revealObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                revealObserver.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.15, rootMargin: "0px 0px -60px 0px" }
        );
        revealEls.forEach((el) => revealObserver.observe(el));
        experienceEntries.forEach((el) => revealObserver.observe(el));
      }

      /* ── Pointer-based interactions (desktop only) ── */
      if (window.matchMedia("(pointer: fine)").matches && !prefersReducedMotion) {
        let mouseX = 0, mouseY = 0;
        let ringX = 0, ringY = 0;
        let glowX = 0, glowY = 0;
        let targetRotX = 0, targetRotY = 0;
        let currentRotX = 0, currentRotY = 0;

        /* Cursor elements */
        const dot = document.createElement("div");
        dot.className = "custom-cursor-dot";
        dot.setAttribute("aria-hidden", "true");
        const ring = document.createElement("div");
        ring.className = "custom-cursor-ring";
        ring.setAttribute("aria-hidden", "true");
        const glow = document.createElement("div");
        glow.className = "cursor-glow";
        glow.setAttribute("aria-hidden", "true");
        document.body.append(dot, ring, glow);

        /* Track mouse */
        document.addEventListener("mousemove", (e) => {
          mouseX = e.clientX;
          mouseY = e.clientY;
          dot.style.left = mouseX + "px";
          dot.style.top = mouseY + "px";
        });

        /* Hover detection via event delegation */
        document.addEventListener("mouseover", (e) => {
          if (e.target.closest("[data-cursor-hover]")) {
            ring.classList.add("hovering");
          }
        });
        document.addEventListener("mouseout", (e) => {
          if (e.target.closest("[data-cursor-hover]") && !e.relatedTarget?.closest("[data-cursor-hover]")) {
            ring.classList.remove("hovering");
          }
        });

        /* Click feedback */
        document.addEventListener("mousedown", () => {
          dot.classList.add("clicking");
          ring.classList.add("clicking");
        });
        document.addEventListener("mouseup", () => {
          setTimeout(() => {
            dot.classList.remove("clicking");
            ring.classList.remove("clicking");
          }, 150);
        });

        /* Hide cursor when leaving viewport */
        document.documentElement.addEventListener("mouseleave", () => {
          dot.style.opacity = "0";
          ring.style.opacity = "0";
          glow.style.opacity = "0";
        });
        document.documentElement.addEventListener("mouseenter", () => {
          dot.style.opacity = "1";
          ring.style.opacity = "1";
          glow.style.opacity = "1";
        });

        /* Magnetic elements */
        document.querySelectorAll("[data-magnetic]").forEach((el) => {
          el.addEventListener("mousemove", (e) => {
            const rect = el.getBoundingClientRect();
            const cx = rect.left + rect.width / 2;
            const cy = rect.top + rect.height / 2;
            const dx = (e.clientX - cx) * 0.3;
            const dy = (e.clientY - cy) * 0.3;
            el.style.transform = `translate(${dx}px, ${dy}px)`;
          });
          el.addEventListener("mouseleave", () => {
            el.style.transform = "translate(0, 0)";
            el.style.transition = "transform 200ms ease-out";
          });
          el.addEventListener("mouseenter", () => {
            el.style.transition = "none";
          });
        });

        /* Hero photo 3D tilt */
        const heroSection = document.querySelector("[data-hero-section]");
        const photoFrame = document.querySelector("[data-3d-photo] .hero-photo-frame");

        if (heroSection && photoFrame) {
          heroSection.addEventListener("mousemove", (e) => {
            const photoShell = document.querySelector("[data-3d-photo]");
            if (!photoShell) return;
            const rect = photoShell.getBoundingClientRect();
            const cx = rect.left + rect.width / 2;
            const cy = rect.top + rect.height / 2;
            const dx = (e.clientX - cx) / (rect.width / 2);
            const dy = (e.clientY - cy) / (rect.height / 2);
            targetRotY = Math.max(-12, Math.min(12, dx * 12));
            targetRotX = Math.max(-12, Math.min(12, -dy * 12));
          });

          heroSection.addEventListener("mouseleave", () => {
            targetRotX = 0;
            targetRotY = 0;
          });
        }

        /* Single rAF loop */
        function animationLoop() {
          ringX += (mouseX - ringX) * 0.25;
          ringY += (mouseY - ringY) * 0.25;
          ring.style.left = ringX + "px";
          ring.style.top = ringY + "px";

          glowX += (mouseX - glowX) * 0.08;
          glowY += (mouseY - glowY) * 0.08;
          glow.style.left = glowX + "px";
          glow.style.top = glowY + "px";

          if (photoFrame) {
            currentRotX += (targetRotX - currentRotX) * 0.08;
            currentRotY += (targetRotY - currentRotY) * 0.08;
            photoFrame.style.transform = `rotateX(${currentRotX}deg) rotateY(${currentRotY}deg)`;
          }

          requestAnimationFrame(animationLoop);
        }
        requestAnimationFrame(animationLoop);
      }
    </script>
  </body>
</html>
