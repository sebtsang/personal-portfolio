---
import BaseLayout from "../layouts/BaseLayout.astro";
import ExperienceItem from "../components/ExperienceItem.astro";
import HeaderBar from "../components/HeaderBar.astro";
import SocialLinks from "../components/SocialLinks.astro";
import {
  experience,
  navItems,
  profile,
  socialLinks,
} from "../data/site";
---

<BaseLayout title="Sebastian Tsang | Portfolio">
  <div id="top" class="mx-auto max-w-6xl px-6 md:px-10">
    <HeaderBar name={profile.name} navItems={navItems} />

    <main class="py-8 md:py-10">
    <section class="border-b border-line/80 pb-14 pt-10 md:pb-18 md:pt-14" data-hero-section>
      <div class="mx-auto grid max-w-4xl gap-10 md:grid-cols-[minmax(0,1fr)_120px] md:items-center md:gap-10">
        <div class="max-w-3xl">
          <h1 class="hero-load hero-load-1 max-w-4xl font-sans text-[3.7rem] font-light leading-[0.94] tracking-[-0.055em] text-ink md:text-[5.4rem]">
            {profile.name}
          </h1>
          <p class="hero-load hero-load-2 mt-4 max-w-2xl font-mono text-sm uppercase tracking-[0.18em] text-muted md:text-[0.95rem]">
            {profile.headline}
          </p>
          <p class="hero-load hero-load-3 mt-5 max-w-xl text-base leading-7 text-muted md:text-[1.02rem]">
            {profile.intro}
          </p>
          <div class="hero-load hero-load-4 mt-6">
            <SocialLinks links={socialLinks} />
          </div>
        </div>

        <div class="hero-load hero-load-5 hero-photo-shell hero-photo-shell--compact" data-3d-photo>
          <div class="hero-photo-frame">
            <img
              src={profile.photo}
              alt={profile.photoAlt}
              class="hero-photo"
              loading="eager"
              decoding="async"
            />
          </div>
        </div>
      </div>
    </section>

    <section id="experience" class="divider scroll-mt-24 py-14 md:py-18">
      <div class="mx-auto max-w-4xl">
        <p class="section-label reveal">Experience</p>
        <div class="experience-timeline reveal reveal-stagger-1 mt-6 md:mt-7" data-timeline>
          <div class="experience-timeline__progress" aria-hidden="true"></div>
          {experience.map((item) => <ExperienceItem {...item} />)}
        </div>
      </div>
    </section>

    <section id="contact" class="divider scroll-mt-24 py-14 md:py-18">
      <div class="mx-auto max-w-4xl">
        <p class="section-label reveal">Contact</p>
        <div class="mt-6 text-center reveal reveal-stagger-1">
          <p class="mx-auto max-w-xl text-base leading-7 text-muted md:text-[1.02rem]">
            Reach out by email or connect on LinkedIn.
          </p>
          <div class="mt-5 flex flex-wrap items-center justify-center gap-x-5 gap-y-3 text-sm md:text-base">
            <a class="story-link" href={`mailto:${profile.email}`} data-cursor-hover>Email</a>
            <a class="story-link" href={profile.linkedin} target="_blank" rel="noreferrer" data-cursor-hover>LinkedIn</a>
            <a class="story-link" href={profile.github} target="_blank" rel="noreferrer" data-cursor-hover>GitHub</a>
          </div>
        </div>
      </div>
    </section>
    </main>
  </div>
</BaseLayout>
