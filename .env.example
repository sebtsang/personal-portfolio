# ─────────────────────────────────────────────────────────────
# LLM provider — pick one. Defaults to ollama if unset.
# ─────────────────────────────────────────────────────────────

LLM_PROVIDER=ollama        # one of: ollama | claude | openai
# LLM_MODEL=qwen3.5:cloud  # optional override; each provider has a default

# ─────────────────────────────────────────────────────────────
# Ollama — set if LLM_PROVIDER=ollama
# ─────────────────────────────────────────────────────────────

# LOCAL daemon: leave both blank (or set OLLAMA_BASE_URL to http://localhost:11434)
# OLLAMA CLOUD: set OLLAMA_API_KEY; base URL auto-resolves to https://ollama.com
# OLLAMA_BASE_URL=https://ollama.com
# OLLAMA_API_KEY=your-ollama-key

# ─────────────────────────────────────────────────────────────
# Claude — set if LLM_PROVIDER=claude
# Get key at https://console.anthropic.com/
# Default model: claude-haiku-4-5-20251001
# ─────────────────────────────────────────────────────────────

# ANTHROPIC_API_KEY=sk-ant-...

# ─────────────────────────────────────────────────────────────
# OpenAI — set if LLM_PROVIDER=openai
# Get key at https://platform.openai.com/api-keys
# Default model: gpt-4.1-mini
# ─────────────────────────────────────────────────────────────

# OPENAI_API_KEY=sk-...

# ─────────────────────────────────────────────────────────────
# Upstash Redis — required for rate limiting + logging in production.
# Install the Vercel-Upstash integration:
# https://vercel.com/integrations/upstash → auto-populates these vars
# on deploy. Leave blank in local dev — ratelimit + logging fail-open.
# ─────────────────────────────────────────────────────────────

# UPSTASH_REDIS_REST_URL=https://<your-db>.upstash.io
# UPSTASH_REDIS_REST_TOKEN=...

# ─────────────────────────────────────────────────────────────
# Logging — static salt for hashing IPs before writing to Redis.
# Generate with `openssl rand -hex 16`. If unset, logging still
# works but IPs are hashed with a weak default (dev only).
# ─────────────────────────────────────────────────────────────

# LOG_SALT=...
